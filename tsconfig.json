{
  "compilerOptions": {
    // Editor Support
    "plugins": [
      {
        "name": "next"
      }
    ],
    // Emit
    "noEmit": true,
    // Completeness
    "skipLibCheck": true,
    // JavaScript Support
    "allowJs": true,
    // Language and Environment
    "jsx": "preserve",
    "lib": ["DOM.Iterable", "DOM", "ESNext"],
    // Modules
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      // Main Folders
      "@app/*": ["./src/app/*"],
      "@features/*": ["./src/features/*"],
      "@shared/*": ["./src/shared/*"],
      // Styles
      "@styles/*": ["./src/shared/styles/*"],
      "@fullscreen/*": ["./src/shared/ui/fullscreen/*"],
      "@main/*": ["./src/shared/ui/main/*"],
      "@switcher/*": ["./src/shared/ui/switcher/*"],
      "@wrapper/*": ["./src/shared/ui/wrapper/*"],
      // Effects
      "@effects/*": ["./src/shared/styles/effects/*"],
    },
    "resolveJsonModule": true,
    // Projects
    "disableReferencedProjectLoad": true,
    "incremental": true,
    // Type Checking
    "allowUnreachableCode": false,
    "allowUnusedLabels": false,
    "exactOptionalPropertyTypes": true,
    "noImplicitAny": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "strict": true,
    // Interop Constraints
    "esModuleInterop": true,
    "isolatedModules": true
  },
  "exclude": ["node_modules"],
  "include": ["**/*.tsx", "**/*.ts", ".next/types/**/*.ts", "next-env.d.ts"]
}
